{
  "name": "next-secrets",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "node validate-env.mts && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest --passWithNoTests -c vitest-unit.config.ts",
    "test:integration": "vitest -c vitest-integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ci": "npm run test:unit && npm run test:integration",
    "test:e2e:ci": "start-server-and-test 'npm run build && npm run start' http://localhost:3000 'playwright test'",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "husky",
    "dev:docker": "docker compose up",
    "dev:docker:detached": "docker compose up -d",
    "dev:docker:down": "docker compose down",
    "dev:docker:down:volumes": "docker compose down -v",
    "dev:docker:logs": "docker compose logs -f app",
    "dev:docker:sh": "docker compose exec app sh",
    "dev:docker:prisma:migrate": "docker compose exec app pnpm prisma migrate dev",
    "dev:docker:prisma:seed": "docker compose exec app pnpm prisma db seed",
    "dev:docker:prisma:studio": "docker compose exec app pnpm prisma studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^10.4.0",
    "@next/env": "16.2.6",
    "@next/eslint-plugin-next": "16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testcontainers/postgresql": "^11.14.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "install": "^0.13.0",
    "lint-staged": "^16.4.0",
    "pg": "^8.21.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4.3.0",
    "testcontainers": "^11.14.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  }
}
